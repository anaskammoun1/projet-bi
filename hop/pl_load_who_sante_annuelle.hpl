<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_load_who_sante_annuelle</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>WHO annual fact loader for Apache Hop.</description>
    <extended_description>Uses PostgreSQL to read data.csv staging and upsert public.fait_sante_annuelle with country-level annual indicators only.</extended_description>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/04/16 12:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/16 20:40:00.000</modified_date>
  </info>
  <notepads/>
  <order/>
  <transform>
    <name>Table input</name>
    <type>TableInput</type>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>projetbi</connection>
    <sql>WITH raw_src AS (
    SELECT
        p.id_pays,
        NULLIF(r.Period, '')::smallint AS annee,
        r.IndicatorCode AS indicator_code,
        COALESCE(NULLIF(r.Indicator, ''), r.IndicatorCode) AS indicator_nom,
        NULLIF(r.FactValueNumeric, '')::numeric(12,4) AS indicator_valeur,
        NULLIF(r.Dim1ValueCode, '') AS who_dim1_code,
        COALESCE(NULLIF(r."Dim1 type", ''), 'WHO_DIM1') AS who_dim1_nom
    FROM public.stg_who_csv_raw r
    JOIN public.dim_pays p
      ON p.pays_code = r.SpatialDimValueCode
    WHERE r."Location type" = 'Country'
      AND NULLIF(r.Period, '') IS NOT NULL
      AND NULLIF(r.IndicatorCode, '') IS NOT NULL
      AND NULLIF(r.FactValueNumeric, '') IS NOT NULL
),
src AS (
    SELECT DISTINCT ON (id_pays, annee, indicator_code)
        id_pays,
        annee,
        indicator_code,
        indicator_nom,
        indicator_valeur,
        who_dim1_code,
        who_dim1_nom
    FROM raw_src
    ORDER BY
        id_pays,
        annee,
        indicator_code,
        CASE WHEN who_dim1_code IS NULL THEN 1 ELSE 0 END,
        who_dim1_code,
        indicator_valeur DESC
),
upserted AS (
    INSERT INTO public.fait_sante_annuelle (
        id_pays,
        annee,
        indicator_code,
        indicator_nom,
        indicator_valeur,
        who_dim1_code,
        who_dim1_nom
    )
    SELECT
        id_pays,
        annee,
        indicator_code,
        indicator_nom,
        indicator_valeur,
        who_dim1_code,
        who_dim1_nom
    FROM src
    ON CONFLICT (annee, id_pays, indicator_code) DO UPDATE
    SET indicator_nom = EXCLUDED.indicator_nom,
        indicator_valeur = EXCLUDED.indicator_valeur,
        who_dim1_code = EXCLUDED.who_dim1_code,
        who_dim1_nom = EXCLUDED.who_dim1_nom,
        charge_le_utc = CURRENT_TIMESTAMP
    RETURNING 1
)
SELECT COUNT(*) AS upserted_rows
FROM upserted;</sql>
    <limit>0</limit>
    <attributes/>
    <GUI>
      <xloc>304</xloc>
      <yloc>176</yloc>
    </GUI>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
