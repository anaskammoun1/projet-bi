<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_api_sensor_measurements_raw</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Discover OpenAQ sensors from raw locations and store raw sensor measurements.</description>
    <extended_description>Reads public.stg_pollution_json_raw, derives sensor_id and parameter_code from the OpenAQ location payload, then calls /v3/sensors/{sensor_id}/measurements.</extended_description>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/04/16 20:45:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/16 20:45:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop><from>Table input sensor catalog</from><to>Add request constants</to><enabled>Y</enabled></hop>
    <hop><from>Add request constants</from><to>Build full URL</to><enabled>Y</enabled></hop>
    <hop><from>Build full URL</from><to>REST client OpenAQ measurements</to><enabled>Y</enabled></hop>
    <hop><from>REST client OpenAQ measurements</from><to>Select staging fields</to><enabled>Y</enabled></hop>
    <hop><from>Select staging fields</from><to>Table output</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Table input sensor catalog</name>
    <type>TableInput</type>
    <description>Extract distinct sensor IDs and pollutant codes from raw location JSON.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>projetbi</connection>
    <sql>SELECT DISTINCT
    r.station_code,
    r.openaq_location_id,
    (sensor -&gt;&gt; 'id')::integer AS sensor_id,
    LOWER(sensor -&gt; 'parameter' -&gt;&gt; 'name') AS parameter_code
FROM public.stg_pollution_json_raw r
CROSS JOIN LATERAL jsonb_array_elements(
    CASE
        WHEN jsonb_typeof(r.api_result::jsonb -&gt; 'results') = 'array'
            THEN r.api_result::jsonb -&gt; 'results'
        ELSE jsonb_build_array(r.api_result::jsonb)
    END
) AS result_item
CROSS JOIN LATERAL jsonb_array_elements(
    COALESCE(result_item -&gt; 'sensors', '[]'::jsonb)
) AS sensor
WHERE jsonb_exists(sensor, 'id')
  AND sensor -&gt; 'parameter' -&gt;&gt; 'name' IS NOT NULL;</sql>
    <limit>0</limit>
    <attributes/>
    <GUI><xloc>128</xloc><yloc>224</yloc></GUI>
  </transform>
  <transform>
    <name>Add request constants</name>
    <type>Constant</type>
    <description>OpenAQ sensor base URL and API key.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><length>-1</length><name>base_url</name><nullif>https://api.openaq.org/v3/sensors</nullif><precision>-1</precision><set_empty_string>N</set_empty_string><type>String</type></field>
      <field><length>-1</length><name>api_key</name><nullif>fc130f19093c85158767f8efeddbc641f8914a347d83c50f9f71a96251528f9c</nullif><precision>-1</precision><set_empty_string>N</set_empty_string><type>String</type></field>
    </fields>
    <attributes/>
    <GUI><xloc>352</xloc><yloc>224</yloc></GUI>
  </transform>
  <transform>
    <name>Build full URL</name>
    <type>Formula</type>
    <description>Construct https://api.openaq.org/v3/sensors/{sensor_id}/measurements.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <formulas>
      <formula><field_name>full_url</field_name><formula>CONCATENATE([base_url],"/",TEXT([sensor_id],"0"),"/measurements")</formula><replace_field/><set_na>N</set_na><value_length>-1</value_length><value_precision>-1</value_precision><value_type>2</value_type></formula>
    </formulas>
    <attributes/>
    <GUI><xloc>576</xloc><yloc>224</yloc></GUI>
  </transform>
  <transform>
    <name>REST client OpenAQ measurements</name>
    <type>Rest</type>
    <description>GET request to OpenAQ sensor measurement endpoint.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <applicationType>TEXT PLAIN</applicationType>
    <bodyField/>
    <connectionTimeout>10000</connectionTimeout>
    <connection_name/>
    <dynamicMethod>N</dynamicMethod>
    <headers>
      <header><field>api_key</field><name>X-API-Key</name></header>
    </headers>
    <httpLogin/>
    <httpPassword>Encrypted </httpPassword>
    <ignoreSsl>N</ignoreSsl>
    <matrixParameters/>
    <method>GET</method>
    <methodFieldName/>
    <parameters/>
    <preemptive>N</preemptive>
    <proxyHost/>
    <proxyPort/>
    <readTimeout>10000</readTimeout>
    <result><code/><name>api_result</name><response_header/><response_time/></result>
    <trustStoreFile/>
    <trustStorePassword>Encrypted </trustStorePassword>
    <url/>
    <urlField>full_url</urlField>
    <urlInField>Y</urlInField>
    <attributes/>
    <GUI><xloc>800</xloc><yloc>224</yloc></GUI>
  </transform>
  <transform>
    <name>Select staging fields</name>
    <type>SelectValues</type>
    <description>Keep fields required for the raw sensor staging table.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><length>-2</length><name>station_code</name><precision>-2</precision><rename>station_code</rename></field>
      <field><length>-2</length><name>openaq_location_id</name><precision>-2</precision><rename>openaq_location_id</rename></field>
      <field><length>-2</length><name>sensor_id</name><precision>-2</precision><rename>sensor_id</rename></field>
      <field><length>-2</length><name>parameter_code</name><precision>-2</precision><rename>parameter_code</rename></field>
      <field><length>-2</length><name>api_result</name><precision>-2</precision><rename>api_result</rename></field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI><xloc>1024</xloc><yloc>224</yloc></GUI>
  </transform>
  <transform>
    <name>Table output</name>
    <type>TableOutput</type>
    <description>Persist raw sensor payloads in PostgreSQL.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <add_columns>N</add_columns>
    <always_drop_and_recreate>N</always_drop_and_recreate>
    <auto_update_table_structure>N</auto_update_table_structure>
    <change_column_types>N</change_column_types>
    <commit>1000</commit>
    <connection>projetbi</connection>
    <drop_columns>N</drop_columns>
    <fields>
      <field><column_name>station_code</column_name><stream_name>station_code</stream_name></field>
      <field><column_name>openaq_location_id</column_name><stream_name>openaq_location_id</stream_name></field>
      <field><column_name>sensor_id</column_name><stream_name>sensor_id</stream_name></field>
      <field><column_name>parameter_code</column_name><stream_name>parameter_code</stream_name></field>
      <field><column_name>api_result</column_name><stream_name>api_result</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_field/>
    <return_keys>N</return_keys>
    <schema>public</schema>
    <specify_fields>Y</specify_fields>
    <table>stg_sensor_measurements_raw</table>
    <tablename_field/>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>1312</xloc><yloc>224</yloc></GUI>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
