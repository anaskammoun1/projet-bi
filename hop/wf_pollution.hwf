<workflow>
  <name>wf_pollution</name>
  <name_sync_with_filename>Y</name_sync_with_filename>
  <description>OpenAQ orchestration for raw loads, dimensions and pollution fact refresh.</description>
  <extended_description>Creates staging, loads raw locations and sensor measurements, flattens JSON, refreshes dim_station and dim_temps, then upserts fait_pollution_heure.</extended_description>
