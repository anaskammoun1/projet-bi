<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_api_pollution_raw</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Call OpenAQ location endpoint for reference stations and store raw payloads.</description>
    <extended_description>Each row carries station metadata and the raw JSON returned by /v3/locations/{location_id}.</extended_description>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/04/16 20:45:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/16 20:45:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop><from>Data grid locations</from><to>Add request constants</to><enabled>Y</enabled></hop>
    <hop><from>Add request constants</from><to>Build full URL</to><enabled>Y</enabled></hop>
    <hop><from>Build full URL</from><to>REST client OpenAQ location</to><enabled>Y</enabled></hop>
    <hop><from>REST client OpenAQ location</from><to>Select staging fields</to><enabled>Y</enabled></hop>
    <hop><from>Select staging fields</from><to>Table output</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>Data grid locations</name>
    <type>DataGrid</type>
    <description>Reference stations and OpenAQ location identifiers.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <data>
      <line><item>FRA</item><item>France</item><item>PARIS_4039</item><item>Paris</item><item>4039</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>GBR</item><item>United Kingdom</item><item>LONDON_148</item><item>London</item><item>148</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>DEU</item><item>Germany</item><item>BERLIN_2993</item><item>Berlin</item><item>2993</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>ESP</item><item>Spain</item><item>MADRID_3223</item><item>Madrid</item><item>3223</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>SEN</item><item>Senegal</item><item>DAKAR_1531944</item><item>Dakar</item><item>1531944</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>EGY</item><item>Egypt</item><item>CAIRO_1621200</item><item>Cairo</item><item>1621200</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>IND</item><item>India</item><item>DELHI_17</item><item>Delhi</item><item>17</item><item>2016-01-01</item><item>2026-12-31</item></line>
      <line><item>CHN</item><item>China</item><item>BEIJING_8833</item><item>Beijing</item><item>8833</item><item>2016-01-01</item><item>2026-12-31</item></line>
    </data>
    <fields>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>pays_code</name><type>String</type></field>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>pays_nom</name><type>String</type></field>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>station_code</name><type>String</type></field>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>city</name><type>String</type></field>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>location_id</name><type>Integer</type></field>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>datetime_from</name><type>String</type></field>
      <field><length>-1</length><precision>-1</precision><set_empty_string>N</set_empty_string><name>datetime_to</name><type>String</type></field>
    </fields>
    <attributes/>
    <GUI><xloc>128</xloc><yloc>352</yloc></GUI>
  </transform>
  <transform>
    <name>Add request constants</name>
    <type>Constant</type>
    <description>OpenAQ base URL and API key.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><length>-1</length><name>base_url</name><nullif>https://api.openaq.org/v3/locations</nullif><precision>-1</precision><set_empty_string>N</set_empty_string><type>String</type></field>
      <field><length>-1</length><name>api_key</name><nullif>fc130f19093c85158767f8efeddbc641f8914a347d83c50f9f71a96251528f9c</nullif><precision>-1</precision><set_empty_string>N</set_empty_string><type>String</type></field>
    </fields>
    <attributes/>
    <GUI><xloc>352</xloc><yloc>352</yloc></GUI>
  </transform>
  <transform>
    <name>Build full URL</name>
    <type>Formula</type>
    <description>Construct https://api.openaq.org/v3/locations/{location_id}.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <formulas>
      <formula><field_name>full_url</field_name><formula>CONCATENATE([base_url],"/",TEXT([location_id],"0"))</formula><replace_field/><set_na>N</set_na><value_length>-1</value_length><value_precision>-1</value_precision><value_type>2</value_type></formula>
    </formulas>
    <attributes/>
    <GUI><xloc>560</xloc><yloc>352</yloc></GUI>
  </transform>
  <transform>
    <name>REST client OpenAQ location</name>
    <type>Rest</type>
    <description>GET request to OpenAQ location endpoint.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <applicationType>TEXT PLAIN</applicationType>
    <bodyField/>
    <connectionTimeout>10000</connectionTimeout>
    <connection_name/>
    <dynamicMethod>N</dynamicMethod>
    <headers>
      <header><field>api_key</field><name>X-API-Key</name></header>
    </headers>
    <httpLogin/>
    <httpPassword>Encrypted </httpPassword>
    <ignoreSsl>N</ignoreSsl>
    <matrixParameters/>
    <method>GET</method>
    <methodFieldName/>
    <parameters/>
    <preemptive>N</preemptive>
    <proxyHost/>
    <proxyPort/>
    <readTimeout>10000</readTimeout>
    <result><code/><name>api_result</name><response_header/><response_time/></result>
    <trustStoreFile/>
    <trustStorePassword>Encrypted </trustStorePassword>
    <url/>
    <urlField>full_url</urlField>
    <urlInField>Y</urlInField>
    <attributes/>
    <GUI><xloc>768</xloc><yloc>352</yloc></GUI>
  </transform>
  <transform>
    <name>Select staging fields</name>
    <type>SelectValues</type>
    <description>Rename location_id to openaq_location_id and keep staging metadata.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><length>-2</length><name>pays_code</name><precision>-2</precision><rename>pays_code</rename></field>
      <field><length>-2</length><name>pays_nom</name><precision>-2</precision><rename>pays_nom</rename></field>
      <field><length>-2</length><name>station_code</name><precision>-2</precision><rename>station_code</rename></field>
      <field><length>-2</length><name>city</name><precision>-2</precision><rename>city</rename></field>
      <field><length>-2</length><name>location_id</name><precision>0</precision><rename>openaq_location_id</rename></field>
      <field><length>-2</length><name>datetime_from</name><precision>-2</precision><rename>datetime_from</rename></field>
      <field><length>-2</length><name>datetime_to</name><precision>-2</precision><rename>datetime_to</rename></field>
      <field><length>-2</length><name>api_result</name><precision>-2</precision><rename>api_result</rename></field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI><xloc>992</xloc><yloc>352</yloc></GUI>
  </transform>
  <transform>
    <name>Table output</name>
    <type>TableOutput</type>
    <description>Persist raw location payloads in PostgreSQL.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <add_columns>N</add_columns>
    <always_drop_and_recreate>N</always_drop_and_recreate>
    <auto_update_table_structure>N</auto_update_table_structure>
    <change_column_types>N</change_column_types>
    <commit>1000</commit>
    <connection>projetbi</connection>
    <drop_columns>N</drop_columns>
    <fields>
      <field><column_name>pays_code</column_name><stream_name>pays_code</stream_name></field>
      <field><column_name>pays_nom</column_name><stream_name>pays_nom</stream_name></field>
      <field><column_name>station_code</column_name><stream_name>station_code</stream_name></field>
      <field><column_name>city</column_name><stream_name>city</stream_name></field>
      <field><column_name>openaq_location_id</column_name><stream_name>openaq_location_id</stream_name></field>
      <field><column_name>datetime_from</column_name><stream_name>datetime_from</stream_name></field>
      <field><column_name>datetime_to</column_name><stream_name>datetime_to</stream_name></field>
      <field><column_name>api_result</column_name><stream_name>api_result</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_field/>
    <return_keys>N</return_keys>
    <schema>public</schema>
    <specify_fields>Y</specify_fields>
    <table>stg_pollution_json_raw</table>
    <tablename_field/>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>1280</xloc><yloc>352</yloc></GUI>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
