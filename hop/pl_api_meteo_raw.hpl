<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_api_meteo_raw</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Canonical Open-Meteo raw loader for Apache Hop.</description>
    <extended_description>Calls Open-Meteo and stores the raw JSON into public.stg_meteo_json_raw.</extended_description>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/04/16 12:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/16 12:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop>
      <from>Table input active stations</from>
      <to>Add constants</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Add constants</from>
      <to>REST client</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>REST client</from>
      <to>Select values</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Select values</from>
      <to>Table output</to>
      <enabled>Y</enabled>
    </hop>
  </order>
  <transform>
    <name>Table input active stations</name>
    <type>TableInput</type>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <connection>projetbi</connection>
    <sql>WITH station_window AS (
    SELECT
        s.station_code,
        s.latitude,
        s.longitude,
        COALESCE(
            (
                SELECT MAX(m.end_date::date) + 1
                FROM public.stg_meteo_json_raw m
                WHERE m.station_code = s.station_code
                  AND m.end_date ~ '^[0-9]{4}-[0-9]{2}-[0-9]{2}$'
            ),
            GREATEST(s.datetime_first_utc::date, DATE '2016-01-01')
        ) AS start_date,
        LEAST(CURRENT_DATE - INTERVAL '2 days', s.datetime_last_utc::date)::date AS end_date
    FROM public.dim_station s
    WHERE s.is_active = true
      AND s.datetime_last_utc::date &gt;= CURRENT_DATE - INTERVAL '180 days'
      AND s.datetime_first_utc::date &lt;= CURRENT_DATE - INTERVAL '2 days'
)
SELECT
    station_code,
    latitude,
    longitude,
    to_char(start_date, 'YYYY-MM-DD') AS start_date,
    to_char(end_date, 'YYYY-MM-DD') AS end_date
FROM station_window
WHERE start_date &lt;= end_date;</sql>
    <limit>0</limit>
    <attributes/>
    <GUI><xloc>160</xloc><yloc>240</yloc></GUI>
  </transform>
  <transform>
    <name>Add constants</name>
    <type>Constant</type>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field><name>base_url</name><type>String</type><length>-1</length><precision>-1</precision><currency/><set_empty_string>N</set_empty_string><nullif>https://archive-api.open-meteo.com/v1/archive</nullif><format/><group/><decimal/></field>
      <field><name>hourly</name><type>String</type><length>-1</length><precision>-1</precision><currency/><set_empty_string>N</set_empty_string><nullif>temperature_2m,relative_humidity_2m,wind_speed_10m,precipitation</nullif><format/><group/><decimal/></field>
      <field><name>timezone</name><type>String</type><length>-1</length><precision>-1</precision><currency/><set_empty_string>N</set_empty_string><nullif>GMT</nullif><format/><group/><decimal/></field>
    </fields>
    <attributes/>
    <GUI><xloc>336</xloc><yloc>240</yloc></GUI>
  </transform>
  <transform>
    <name>REST client</name>
    <type>Rest</type>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <applicationType>TEXT PLAIN</applicationType>
    <bodyField/>
    <connectionTimeout>10000</connectionTimeout>
    <connection_name/>
    <dynamicMethod>N</dynamicMethod>
    <headers/>
    <httpLogin/>
    <httpPassword>Encrypted </httpPassword>
    <ignoreSsl>N</ignoreSsl>
    <matrixParameters/>
    <method>GET</method>
    <methodFieldName/>
    <parameters>
      <parameter><field>latitude</field><name>latitude</name></parameter>
      <parameter><field>longitude</field><name>longitude</name></parameter>
      <parameter><field>start_date</field><name>start_date</name></parameter>
      <parameter><field>end_date</field><name>end_date</name></parameter>
      <parameter><field>hourly</field><name>hourly</name></parameter>
      <parameter><field>timezone</field><name>timezone</name></parameter>
    </parameters>
    <preemptive>N</preemptive>
    <proxyHost/>
    <proxyPort/>
    <readTimeout>10000</readTimeout>
    <result>
      <code/>
      <name>api_result</name>
      <response_header/>
      <response_time/>
    </result>
    <trustStoreFile/>
    <trustStorePassword>Encrypted </trustStorePassword>
    <url/>
    <urlField>base_url</urlField>
    <urlInField>Y</urlInField>
    <attributes/>
    <GUI><xloc>512</xloc><yloc>256</yloc></GUI>
  </transform>
  <transform>
    <name>Select values</name>
    <type>SelectValues</type>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <fields>
      <field><name>station_code</name><precision>-2</precision><length>-2</length><rename/></field>
      <field><name>latitude</name><precision>-2</precision><length>-2</length><rename/></field>
      <field><name>longitude</name><precision>-2</precision><length>-2</length><rename/></field>
      <field><name>start_date</name><precision>-2</precision><length>-2</length><rename/></field>
      <field><name>end_date</name><precision>-2</precision><length>-2</length><rename/></field>
      <field><name>api_result</name><precision>-2</precision><length>-2</length><rename/></field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI><xloc>720</xloc><yloc>288</yloc></GUI>
  </transform>
  <transform>
    <name>Table output</name>
    <type>TableOutput</type>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning>
      <method>none</method>
      <schema_name/>
    </partitioning>
    <add_columns>N</add_columns>
    <always_drop_and_recreate>N</always_drop_and_recreate>
    <auto_update_table_structure>N</auto_update_table_structure>
    <change_column_types>N</change_column_types>
    <commit>1000</commit>
    <connection>projetbi</connection>
    <drop_columns>N</drop_columns>
    <fields>
      <field><column_name>station_code</column_name><stream_name>station_code</stream_name></field>
      <field><column_name>latitude</column_name><stream_name>latitude</stream_name></field>
      <field><column_name>longitude</column_name><stream_name>longitude</stream_name></field>
      <field><column_name>start_date</column_name><stream_name>start_date</stream_name></field>
      <field><column_name>end_date</column_name><stream_name>end_date</stream_name></field>
      <field><column_name>api_result</column_name><stream_name>api_result</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors>
    <only_when_have_rows>N</only_when_have_rows>
    <partitioning_daily>N</partitioning_daily>
    <partitioning_enabled>N</partitioning_enabled>
    <partitioning_field/>
    <partitioning_monthly>Y</partitioning_monthly>
    <return_field/>
    <return_keys>N</return_keys>
    <schema>public</schema>
    <specify_fields>Y</specify_fields>
    <table>stg_meteo_json_raw</table>
    <tablename_field/>
    <tablename_in_field>N</tablename_in_field>
    <tablename_in_table>Y</tablename_in_table>
    <truncate>N</truncate>
    <use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>928</xloc><yloc>336</yloc></GUI>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
