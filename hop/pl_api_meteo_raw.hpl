    <modified_user>-</modified_user>
    <modified_date>2026/04/16 12:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop>
      <from>Data grid</from>
      <to>Add constants</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Add constants</from>
      <to>REST client</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>REST client</from>
      <to>Select values</to>
      <enabled>Y</enabled>
    </hop>
    <hop>
      <from>Select values</from>
      <to>Table output</to>
      <enabled>Y</enabled>
    </hop>
  </order>
