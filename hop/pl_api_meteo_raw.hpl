      <field><name>hourly</name><type>String</type><length>-1</length><precision>-1</precision><currency/><set_empty_string>N</set_empty_string><nullif>temperature_2m,relative_humidity_2m,wind_speed_10m,precipitation</nullif><format/><group/><decimal/></field>
      <field><name>timezone</name><type>String</type><length>-1</length><precision>-1</precision><currency/><set_empty_string>N</set_empty_string><nullif>GMT</nullif><format/><group/><decimal/></field>
