<?xml version="1.0" encoding="UTF-8"?>
<pipeline>
  <info>
    <name>pl_file_pm25_csv_raw</name>
    <name_sync_with_filename>Y</name_sync_with_filename>
    <description>Load OWID PM2.5 exposure CSV into PostgreSQL staging.</description>
    <extended_description>Reads pm25-air-pollution.csv and stores rows in public.stg_pm25_csv_raw.</extended_description>
    <pipeline_version/>
    <pipeline_type>Normal</pipeline_type>
    <parameters/>
    <capture_transform_performance>N</capture_transform_performance>
    <transform_performance_capturing_delay>1000</transform_performance_capturing_delay>
    <transform_performance_capturing_size_limit>100</transform_performance_capturing_size_limit>
    <created_user>-</created_user>
    <created_date>2026/04/29 14:00:00.000</created_date>
    <modified_user>-</modified_user>
    <modified_date>2026/04/29 14:00:00.000</modified_date>
  </info>
  <notepads/>
  <order>
    <hop><from>CSV file input</from><to>Select staging fields</to><enabled>Y</enabled></hop>
    <hop><from>Select staging fields</from><to>Table output</to><enabled>Y</enabled></hop>
  </order>
  <transform>
    <name>CSV file input</name>
    <type>CsvInput</type>
    <description>Read pm25-air-pollution.csv.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <filename>C:\Users\Omar Safi\Desktop\ProjetPowerBI\pm25-air-pollution.csv</filename>
    <filename_field/>
    <rownum_field/>
    <include_filename>N</include_filename>
    <separator>,</separator>
    <delimiter>,</delimiter>
    <enclosure>"</enclosure>
    <escapechar>"</escapechar>
    <header_present>Y</header_present>
    <buffer_size>50000</buffer_size>
    <lazy_conversion_active>N</lazy_conversion_active>
    <add_filename_result>N</add_filename_result>
    <parallel>N</parallel>
    <newline_possible>Y</newline_possible>
    <encoding>UTF-8</encoding>
    <fields>
      <field><name>Entity</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>Code</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>Year</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
      <field><name>Concentrations of fine particulate matter (PM2.5) - Residence area type: Total</name><type>String</type><format/><currency/><decimal/><group/><length>-1</length><precision>-1</precision><trim_type>both</trim_type></field>
    </fields>
    <attributes/>
    <GUI><xloc>128</xloc><yloc>176</yloc></GUI>
  </transform>
  <transform>
    <name>Select staging fields</name>
    <type>SelectValues</type>
    <description>Rename CSV columns to stable staging names.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <fields>
      <field><length>-2</length><name>Entity</name><precision>-2</precision><rename>entity</rename></field>
      <field><length>-2</length><name>Code</name><precision>-2</precision><rename>code</rename></field>
      <field><length>-2</length><name>Year</name><precision>-2</precision><rename>year_value</rename></field>
      <field><length>-2</length><name>Concentrations of fine particulate matter (PM2.5) - Residence area type: Total</name><precision>-2</precision><rename>pm25_exposure_ug_m3</rename></field>
      <select_unspecified>N</select_unspecified>
    </fields>
    <attributes/>
    <GUI><xloc>384</xloc><yloc>176</yloc></GUI>
  </transform>
  <transform>
    <name>Table output</name>
    <type>TableOutput</type>
    <description>Persist PM2.5 CSV rows in PostgreSQL.</description>
    <distribute>Y</distribute>
    <custom_distribution/>
    <copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <add_columns>N</add_columns><always_drop_and_recreate>N</always_drop_and_recreate><auto_update_table_structure>N</auto_update_table_structure><change_column_types>N</change_column_types>
    <commit>1000</commit><connection>projetbi</connection><drop_columns>N</drop_columns>
    <fields>
      <field><column_name>entity</column_name><stream_name>entity</stream_name></field>
      <field><column_name>code</column_name><stream_name>code</stream_name></field>
      <field><column_name>year_value</column_name><stream_name>year_value</stream_name></field>
      <field><column_name>pm25_exposure_ug_m3</column_name><stream_name>pm25_exposure_ug_m3</stream_name></field>
    </fields>
    <ignore_errors>N</ignore_errors><only_when_have_rows>N</only_when_have_rows><partitioning_daily>N</partitioning_daily><partitioning_enabled>N</partitioning_enabled><partitioning_field/><partitioning_monthly>Y</partitioning_monthly>
    <return_field/><return_keys>N</return_keys><schema>public</schema><specify_fields>Y</specify_fields><table>stg_pm25_csv_raw</table><tablename_field/><tablename_in_field>N</tablename_in_field><tablename_in_table>Y</tablename_in_table><truncate>N</truncate><use_batch>Y</use_batch>
    <attributes/>
    <GUI><xloc>656</xloc><yloc>176</yloc></GUI>
  </transform>
  <transform_error_handling/>
  <attributes/>
</pipeline>
