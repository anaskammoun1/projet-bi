      <field><length>-2</length><name>Dim2</name><precision>-2</precision><rename>Dim2</rename></field>
      <field><length>-2</length><name>Dim2ValueCode</name><precision>-2</precision><rename>Dim2ValueCode</rename></field>
      <field><length>-2</length><name>Dim3 type</name><precision>-2</precision><rename>Dim3 type</rename></field>
      <field><length>-2</length><name>Dim3</name><precision>-2</precision><rename>Dim3</rename></field>
      <field><length>-2</length><name>Dim3ValueCode</name><precision>-2</precision><rename>Dim3ValueCode</rename></field>
