      <field><length>-2</length><name>Dim1 type</name><precision>-2</precision><rename>Dim1 type</rename></field>
      <field><length>-2</length><name>Dim1</name><precision>-2</precision><rename>Dim1</rename></field>
      <field><length>-2</length><name>Dim1ValueCode</name><precision>-2</precision><rename>Dim1ValueCode</rename></field>
