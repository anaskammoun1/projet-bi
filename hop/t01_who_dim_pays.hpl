  'ZWE': ['ZW', 'Zimbabwe']
};

var mapEntry = null;
var pays_code = null;
var pays_nom = null;
var continent = null;
var valid_country = false;
var continentMap = { 'AFR': 'Africa', 'AMR': 'Americas', 'EUR': 'Europe', 'EMR': 'Asia', 'SEAR': 'Asia', 'WPR': 'Oceania' };

if (SpatialDimType != null &amp;&amp; SpatialDimType == 'COUNTRY' &amp;&amp; SpatialDim != null) {
  mapEntry = isoMap[SpatialDim];
}

if (mapEntry != null) {
  pays_code = SpatialDim;
  pays_nom = mapEntry[1];
  continent = continentMap[ParentLocationCode];
  valid_country = true;
}</jsScript_script></jsScript></jsScripts>
    <fields>
      <field><name>pays_code</name><rename>pays_code</rename><type>String</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
      <field><name>pays_nom</name><rename>pays_nom</rename><type>String</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
      <field><name>continent</name><rename>continent</rename><type>String</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
      <field><name>valid_country</name><rename>valid_country</rename><type>String</type><length>-1</length><precision>-1</precision><replace>N</replace></field>
    </fields>
    <attributes/><GUI><xloc>416</xloc><yloc>176</yloc></GUI>
  </transform>
  <transform>
    <name>Filter rows</name><type>FilterRows</type><description/><distribute>Y</distribute><custom_distribution/><copies>1</copies>
