    <send_true_to/><send_false_to/>
    <compare><condition><negated>N</negated><leftvalue>valid_country</leftvalue><function>=</function><rightvalue/><value><name>constant</name><type>String</type><text>true</text><length>-1</length><precision>-1</precision><isnull>N</isnull><mask/></value></condition></compare>
    <attributes/><GUI><xloc>656</xloc><yloc>176</yloc></GUI>
  </transform>
  <transform>
    <name>Insert / update</name><type>InsertUpdate</type><description/><distribute>Y</distribute><custom_distribution/><copies>1</copies>
    <partitioning><method>none</method><schema_name/></partitioning>
    <connection>projetbi</connection><commit>100</commit><update_bypassed>N</update_bypassed>
    <lookup><schema>public</schema><table>dim_pays</table><key><name>pays_code</name><field>pays_code</field><condition>=</condition><name2/></key>
      <value><name>pays_code</name><rename>pays_code</rename><update>Y</update></value>
      <value><name>pays_nom</name><rename>pays_nom</rename><update>Y</update></value>
      <value><name>continent</name><rename>continent</rename><update>Y</update></value>
    </lookup>
    <attributes/><GUI><xloc>896</xloc><yloc>176</yloc></GUI>
